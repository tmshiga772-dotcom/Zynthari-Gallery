'use strict';
const { readBin, writeBin, hashPw, ok, err, preflight, parseBody, getUserIdFromEvent } = require('./db');

exports.handler = async (event) => {
  if (event.httpMethod === 'OPTIONS') return preflight();

  try {
    const userId = getUserIdFromEvent(event);
    if (!userId) return err('Authentication required', 401);
    const users = await readBin('users');
    const user = users.find(u => u.id === userId);
    if (!user || user.role !== 'admin') return err('Admin access required', 403);

    if (event.httpMethod === 'GET') {
      const artworks = await readBin('artworks');
      const txns = await readBin('transactions');
      return ok({
        total_users: users.length,
        total_artworks: artworks.length,
        total_transactions: txns.length,
        sellers: users.filter(u=>u.role==='seller').length,
        buyers: users.filter(u=>u.role==='buyer').length,
        users: users.map(u=>({id:u.id,name:u.name,email:u.email,role:u.role,created:u.created})),
        artworks
      });
    }

    if (event.httpMethod === 'POST') {
      const body = parseBody(event);
      const action = body.action;

      if (action === 'delete-artwork') {
        const artworks = await readBin('artworks');
        await writeBin('artworks', artworks.filter(a=>a.id!==body.artworkId));
        return ok({success:true});
      }
      if (action === 'delete-user') {
        if (body.userId === 'admin-001' || body.userId === userId) return ok({success:false, error:'Cannot delete this account'});
        await writeBin('users', users.filter(u=>u.id!==body.userId));
        return ok({success:true});
      }
      if (action === 'change-password') {
        const pw = body.password || '';
        if (pw.length < 8) return ok({success:false, error:'Password must be 8+ chars'});
        const ui = users.findIndex(u=>u.id===userId);
        users[ui].pwHash = hashPw(pw);
        await writeBin('users', users);
        return ok({success:true});
      }
    }
    return err('Unknown action', 400);
  } catch(e) {
    return err('Server error: '+e.message, 500);
  }
};

'use strict';
const { readBin, writeBin, ok, err, preflight, getUserIdFromEvent } = require('./db');

exports.handler = async (event) => {
  if (event.httpMethod === 'OPTIONS') return preflight();
  if (event.httpMethod !== 'DELETE') return err('Method not allowed', 405);
  try {
    const userId = getUserIdFromEvent(event);
    if (!userId) return err('Authentication required', 401);
    const artworkId = (event.queryStringParameters || {}).id;
    if (!artworkId) return err('Artwork ID required');
    const users = await readBin('users');
    const user = users.find(u => u.id === userId);
    if (!user) return err('User not found', 404);
    const artworks = await readBin('artworks');
    const artwork = artworks.find(a => a.id === artworkId);
    if (!artwork) return err('Artwork not found', 404);
    if (artwork.seller_id !== userId && user.role !== 'admin') return err('Unauthorized', 403);
    await writeBin('artworks', artworks.filter(a => a.id !== artworkId));
    return ok({success:true});
  } catch(e) {
    return err('Server error: '+e.message, 500);
  }
};

'use strict';
const { readBin, hashPw, sanitize, ok, err, preflight, parseBody, makeToken } = require('./db');

exports.handler = async (event) => {
  if (event.httpMethod === 'OPTIONS') return preflight();
  if (event.httpMethod !== 'POST') return err('Method not allowed', 405);
  try {
    const body = parseBody(event);
    const email = sanitize(body.email || '').toLowerCase();
    const password = body.password || '';
    if (!email || !password) return ok({success:false, error:'Email and password required'});
    const users = await readBin('users');
    const hash = hashPw(password);
    const user = users.find(u => u.email === email && u.pwHash === hash);
    if (!user) return ok({success:false, error:'Invalid email or password'});
    const sessionToken = makeToken(user.id);
    return ok({
      success: true,
      sessionToken,
      user: {id:user.id, name:user.name, email:user.email, role:user.role, token:user.token||'', paymentMethods:user.paymentMethods||{}}
    });
  } catch(e) {
    console.error('login error:', e.message);
    return err('Server error: '+e.message, 500);
  }
};

'use strict';
const fetch = require('node-fetch');
const MASTER_KEY = process.env.JSONBIN_MASTER_KEY;
const BASE = 'https://api.jsonbin.io/v3/b';
const SESSION_SECRET = process.env.SESSION_SECRET || 'zynthari-2025-secret';
const BINS = {
  users: process.env.JSONBIN_USERS_BIN,
  artworks: process.env.JSONBIN_ARTWORKS_BIN,
  transactions: process.env.JSONBIN_TRANSACTIONS_BIN,
};

async function readBin(name) {
  if (!MASTER_KEY || !BINS[name]) throw new Error('Missing env: '+name);
  const res = await fetch(`${BASE}/${BINS[name]}/latest`, {
    headers: { 'X-Master-Key': MASTER_KEY, 'X-Bin-Meta': 'false' }
  });
  if (!res.ok) throw new Error('readBin '+name+' failed '+res.status);
  const data = await res.json();
  if (data && data.record) return data.record;
  return Array.isArray(data) ? data : [];
}

async function writeBin(name, data) {
  if (!MASTER_KEY || !BINS[name]) throw new Error('Missing env: '+name);
  const res = await fetch(`${BASE}/${BINS[name]}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json', 'X-Master-Key': MASTER_KEY, 'X-Bin-Versioning': 'false' },
    body: JSON.stringify(data)
  });
  if (!res.ok) throw new Error('writeBin '+name+' failed '+res.status);
  return true;
}

function uid() { return 'z'+Math.random().toString(36).slice(2,10)+Date.now().toString(36); }
function genToken() { return 'ZYN-'+Math.random().toString(36).slice(2,9).toUpperCase(); }

function hashPw(pw) {
  let h = 0;
  for (let i = 0; i < pw.length; i++) { h = ((h << 5) - h) + pw.charCodeAt(i); h |= 0; }
  return 'H' + Math.abs(h).toString(16);
}

function sanitize(s) {
  if (!s) return '';
  return String(s).replace(/<[^>]+>/g,'').replace(/javascript:/gi,'').trim().slice(0,2000);
}

function simpleSign(str) {
  let h = 5381;
  for (let i = 0; i < str.length; i++) { h = ((h << 5) + h) ^ str.charCodeAt(i); h |= 0; }
  return Math.abs(h).toString(36);
}

function makeToken(userId) {
  const ts = Date.now();
  const raw = userId + ':' + ts;
  const sig = simpleSign(raw + SESSION_SECRET);
  return Buffer.from(JSON.stringify({raw, sig})).toString('base64');
}

function verifyToken(token) {
  try {
    const obj = JSON.parse(Buffer.from(token, 'base64').toString());
    if (!obj || !obj.raw || !obj.sig) return null;
    if (simpleSign(obj.raw + SESSION_SECRET) !== obj.sig) return null;
    const parts = obj.raw.split(':');
    const ts = parseInt(parts[parts.length - 1]);
    if (Date.now() - ts > 30 * 24 * 60 * 60 * 1000) return null;
    return parts.slice(0, -1).join(':');
  } catch { return null; }
}

function getUserIdFromEvent(event) {
  const auth = (event.headers['authorization'] || event.headers['Authorization'] || '').trim();
  if (!auth.startsWith('Bearer ')) return null;
  return verifyToken(auth.slice(7));
}

const CORS = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'Content-Type, Authorization',
  'Access-Control-Allow-Methods': 'GET, POST, PUT, DELETE, OPTIONS',
  'Content-Type': 'application/json',
};

function ok(data, code=200) { return {statusCode: code, headers: CORS, body: JSON.stringify(data)}; }
function err(msg, code=400) { return {statusCode: code, headers: CORS, body: JSON.stringify({success:false, error:msg})}; }
function preflight() { return {statusCode:204, headers:CORS, body:''}; }

function parseBody(event) {
  const ct = (event.headers['content-type'] || '').toLowerCase();
  const raw = event.body || '';
  if (!raw) return {};
  if (ct.includes('json')) { try { return JSON.parse(raw); } catch { return {}; } }
  if (ct.includes('urlencoded')) {
    const p = new URLSearchParams(raw);
    const o = {}; for (const [k,v] of p.entries()) o[k]=v; return o;
  }
  try { return JSON.parse(raw); } catch { return {}; }
}

module.exports = { readBin, writeBin, uid, genToken, hashPw, sanitize, makeToken, verifyToken, getUserIdFromEvent, ok, err, preflight, parseBody, CORS };

