'use strict';
const { readBin, writeBin, uid, ok, err, preflight, parseBody, getUserIdFromEvent } = require('./db');

exports.handler = async (event) => {
  if (event.httpMethod === 'OPTIONS') return preflight();
  if (event.httpMethod !== 'POST') return err('Method not allowed', 405);
  try {
    const userId = getUserIdFromEvent(event);
    if (!userId) return err('Authentication required', 401);
    const body = parseBody(event);
    const {artworkId, method} = body;
    if (!artworkId) return err('Artwork ID required');

    const users = await readBin('users');
    const buyer = users.find(u => u.id === userId);
    if (!buyer) return err('User not found', 404);

    const pm = buyer.paymentMethods || {};
    const hasPM = pm.card_last_four || pm.paypal_email || pm.payoneer_email || pm.bank_account;
    if (!hasPM) return ok({success:false, error:'Please add a payment method first'});

    const artworks = await readBin('artworks');
    const idx = artworks.findIndex(a => a.id === artworkId);
    if (idx < 0) return err('Artwork not found', 404);
    const artwork = artworks[idx];
    if (artwork.seller_id === userId) return ok({success:false, error:'You cannot buy your own artwork'});

    const now = new Date().toISOString();
    const tx = {
      id: uid(), artwork_id: artworkId, artwork_title: artwork.title,
      seller_id: artwork.seller_id, artist_name: artwork.artist_name,
      buyer_id: userId, buyer_name: buyer.name,
      amount: artwork.price, method: method||'card',
      platform_fee: artwork.price * 0.30,
      seller_earnings: artwork.price * 0.70,
      token: artwork.token, created_at: now, type:'sale'
    };

    const txns = await readBin('transactions');
    txns.push(tx);
    await writeBin('transactions', txns);

    // Update provenance
    artworks[idx].resale_count = (artworks[idx].resale_count||0) + 1;
    if (artworks[idx].provenance) {
      artworks[idx].provenance.resale_count = (artworks[idx].provenance.resale_count||0) + 1;
      artworks[idx].provenance.ownership_history.push({type:'sale', to_name:buyer.name, to_id:userId, price:artwork.price, date:now});
    }
    await writeBin('artworks', artworks);

    return ok({success:true, transaction:tx});
  } catch(e) {
    return err('Server error: '+e.message, 500);
  }
};

'use strict';
const { readBin, writeBin, uid, genToken, sanitize, ok, err, preflight, parseBody, getUserIdFromEvent } = require('./db');

exports.handler = async (event) => {
  if (event.httpMethod === 'OPTIONS') return preflight();

  // GET all artworks — public
  if (event.httpMethod === 'GET') {
    try {
      const artworks = await readBin('artworks');
      return ok(Array.isArray(artworks) ? artworks : []);
    } catch(e) {
      console.error('artworks GET error:', e.message);
      return ok([]);
    }
  }

  // POST new artwork — seller/admin only
  if (event.httpMethod === 'POST') {
    try {
      const userId = getUserIdFromEvent(event);
      if (!userId) return err('Authentication required', 401);

      const users = await readBin('users');
      const user = users.find(u => u.id === userId);
      if (!user || !['seller','admin'].includes(user.role)) return err('Seller account required', 403);

      const body = parseBody(event);
      const title = sanitize(body.title || '');
      const price = parseFloat(body.price) || 0;
      const medium = sanitize(body.medium || 'Original Art');
      const description = sanitize(body.description || '');
      const imageDataUrl = body.imageDataUrl || '';

      if (!title) return ok({success:false, error:'Title is required'});
      if (price <= 0) return ok({success:false, error:'Valid price is required'});
      if (!imageDataUrl || !imageDataUrl.startsWith('data:image')) return ok({success:false, error:'Valid image is required'});

      const artworkId = uid();
      const tok = user.token || genToken();
      const now = new Date().toISOString();

      const artwork = {
        id: artworkId, title, medium, description, price,
        image_url: imageDataUrl,
        seller_id: userId, artist_name: user.name,
        token: tok, verified: true, status: 'active',
        created_at: now, resale_count: 0,
        provenance: {
          token: tok, artist_name: user.name, artist_id: userId,
          created_at: now, resale_count: 0, original_price: price,
          ownership_history: [{type:'creation', to_name:user.name, to_id:userId, price, date:now}]
        }
      };

      const artworks = await readBin('artworks');
      artworks.push(artwork);
      await writeBin('artworks', artworks);

      return ok({success:true, artwork, provenance:{token:tok, certificate_id:'COA-'+artworkId.slice(0,8).toUpperCase()}});
    } catch(e) {
      console.error('artworks POST error:', e.message);
      return err('Server error: '+e.message, 500);
    }
  }

  return err('Method not allowed', 405);
};

'use strict';
const { readBin, writeBin, sanitize, ok, err, preflight, parseBody, getUserIdFromEvent } = require('./db');

exports.handler = async (event) => {
  if (event.httpMethod === 'OPTIONS') return preflight();

  const userId = getUserIdFromEvent(event);
  if (!userId) return err('Authentication required', 401);

  const type = (event.queryStringParameters||{}).type || '';

  try {
    const users = await readBin('users');
    const userIdx = users.findIndex(u => u.id === userId);
    if (userIdx < 0) return err('User not found', 404);
    const user = users[userIdx];

    // GET buyer dashboard
    if (event.httpMethod === 'GET' && type === 'buyer-dashboard') {
      const txns = await readBin('transactions');
      const purchases = txns.filter(t => t.buyer_id === userId);
      const totalSpent = purchases.reduce((s,t) => s + (t.amount||0), 0);
      return ok({
        name: user.name,
        purchases_count: purchases.length,
        total_spent: totalSpent,
        current_value: totalSpent * 1.1,
        purchases: purchases.map(t => ({
          title: t.artwork_title, artist_name: t.artist_name,
          purchase_price: t.amount, current_value: t.amount * 1.1,
          token: t.token||'', date: t.created_at
        })),
        payment_methods: user.paymentMethods || {}
      });
    }

    // GET seller dashboard
    if (event.httpMethod === 'GET' && type === 'seller-dashboard') {
      if (!['seller','admin'].includes(user.role)) return err('Seller access required', 403);
      const artworks = await readBin('artworks');
      const txns = await readBin('transactions');
      const myWorks = artworks.filter(a => a.seller_id === userId);
      const mySales = txns.filter(t => t.seller_id === userId);
      const totalRev = mySales.reduce((s,t) => s+(t.seller_earnings||0), 0);
      return ok({
        name: user.name, token: user.token||'',
        artworks_count: myWorks.length, sales_count: mySales.length,
        total_revenue: totalRev, total_royalties: totalRev * 0.05,
        artworks: myWorks,
        sales: mySales.map(t => ({
          date: t.created_at, artwork_title: t.artwork_title,
          type:'sale', amount: t.amount, earnings: t.seller_earnings||0
        })),
        payment_methods: user.paymentMethods || {}
      });
    }

    // POST update payment methods
    if (event.httpMethod === 'POST' && type === 'payment') {
      const body = parseBody(event);
      const pm = user.paymentMethods || {};
      const m = body.method || '';
      if (m === 'card') { pm.card_last_four=sanitize(body.card_last_four||'').slice(0,4); pm.card_name=sanitize(body.card_name||''); }
      else if (m === 'paypal') { pm.paypal_email=sanitize(body.paypal_email||''); }
      else if (m === 'payoneer') { pm.payoneer_email=sanitize(body.payoneer_email||''); pm.payoneer_name=sanitize(body.payoneer_name||''); }
      else if (m === 'bank') { pm.bank_name=sanitize(body.bank_name||''); pm.bank_holder=sanitize(body.bank_holder||''); pm.bank_account=sanitize(body.bank_account||''); pm.bank_routing=sanitize(body.bank_routing||''); pm.bank_swift=sanitize(body.bank_swift||''); }
      // seller payout fields (no method key)
      if (body.paypal_email && !m) pm.paypal_email=sanitize(body.paypal_email);
      if (body.payoneer_email && !m) { pm.payoneer_email=sanitize(body.payoneer_email); pm.payoneer_name=sanitize(body.payoneer_name||''); }
      if (body.bank_name && !m) { pm.bank_name=sanitize(body.bank_name); pm.bank_holder=sanitize(body.bank_holder||''); pm.bank_account=sanitize(body.bank_account||''); pm.bank_routing=sanitize(body.bank_routing||''); pm.bank_swift=sanitize(body.bank_swift||''); }
      if (body.billing_address) pm.billing_address=sanitize(body.billing_address);
      users[userIdx].paymentMethods = pm;
      await writeBin('users', users);
      return ok({success:true});
    }

    return err('Unknown request', 400);
  } catch(e) {
    console.error('dashboard error:', e.message);
    return err('Server error: '+e.message, 500);
  }
};
